{
  "$schema": "https://stripe.com/stripe-app.schema.json",
  "id": "com.productivity.community-example",
  "name": "Community Example",
  "version": "0.1.0",
  "icon": "./app_icon.png",
  "ui_extension": {
    "views": [
      {
        "viewport": "stripe.dashboard.drawer.default",
        "component": "App"
      }
    ],
    "content_security_policy": {
      "connect-src": [
        "https://your-backend.example.com/api/"
      ],
      "purpose": "Connects to the companion Next.js backend to demonstrate signed-request authentication between a Stripe App and its backend."
    }
  },
  "extensions": null,
  "distribution_type": "private"
}