# ============================================================================
#  Environment variables — copy to .env.local and fill in
#
#  Tip: `npm run setup` (from the repo root) writes .env.local for you —
#  it generates every random secret and walks you through the rest.
# ============================================================================

# ----------------------------------------------------------------------------
# Database (Supabase Postgres)
# Better Auth connects here directly; `npm run db:setup` applies setup.sql
# over this connection. Copy the *Session pooler* connection string from
# your Supabase project (Connect button in the dashboard toolbar).
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Optional — install the tables into a dedicated Postgres schema instead of
# `public`. Lets you reuse a Supabase project you already have without using
# up one of the free tier's limited project slots. `npm run db:setup` creates
# the schema, installs the tables there and grants the API roles access; you
# must then add the schema to "Exposed schemas" in the Supabase dashboard
# (Settings → API) so supabase-js can query it. Use the *Session pooler*
# connection string with this option. Leave unset for public.
# SEE ALSO: https://supabase.com/docs/guides/api/using-custom-schemas
# SUPABASE_SCHEMA=stripe_app  - Default: public

# Supabase API keys (dashboard → Project Settings → API Keys).
# The backend's data access goes through supabase-js with the service-role
# key, which bypasses Row Level Security — keep it server-side only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Not used by the current backend code (it never queries as anon), but
# standard to have around if you add browser-side Supabase access later.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ----------------------------------------------------------------------------
# Better Auth (session auth for browser traffic)
# Create a secret: open Git Bash and run `openssl rand -hex 32`
# ----------------------------------------------------------------------------
BETTER_AUTH_SECRET=your-secret-key-min-32-chars
BETTER_AUTH_URL=http://localhost:3030
# Used by the browser-side auth client; defaults to http://localhost:3030.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3030

# ----------------------------------------------------------------------------
# Stripe API keys & webhook secrets (see src/lib/stripe.ts for the full
# mental model: 2 accounts x 3 environments)
# ----------------------------------------------------------------------------
# Required — the account your Stripe App lives in:
STRIPE_SECRET_KEY_LIVE=sk_live_...
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_SECRET_KEY_MANAGED_SANDBOX=sk_test_...

# Connected accounts are for public apps with a Marketplace listing.
STRIPE_WEBHOOK_SECRET_LIVE_CONNECTED=whsec_...
STRIPE_WEBHOOK_SECRET_TEST_CONNECTED=whsec_...

# Published and public apps
STRIPE_WEBHOOK_SECRET_MANAGED_SANDBOX_CONNECTED=whsec_...

# Optional — self-account webhook events:
# STRIPE_WEBHOOK_SECRET_LIVE_ACCOUNT=whsec_...
# STRIPE_WEBHOOK_SECRET_TEST_ACCOUNT=whsec_...

# Optional — separate billing account (falls back to the app account):
# STRIPE_BILLING_SECRET_KEY_LIVE=sk_live_...
# STRIPE_BILLING_SECRET_KEY_TEST=sk_test_...
# STRIPE_BILLING_WEBHOOK_SECRET_LIVE=whsec_...
# STRIPE_BILLING_WEBHOOK_SECRET_TEST=whsec_...

# ============================================================================
#  Proxy authentication (src/proxy.ts + src/lib/proxy-auth.ts)
#  One variable per auth flavor.
# ============================================================================

# --- Stripe App signature auth ---------------------------------------------
# The "Signing secret" from your app's settings page in the Stripe
# Developers Dashboard (https://dashboard.stripe.com/apps → your app).
# Verifies the `stripe-signature` header sent by fetchStripeSignature()
# in the UI extension.

#
# NOTE: this secret only exists AFTER you run `stripe apps upload` once —
# locally previewed apps don't have one. Uploading is NOT publishing: the
# app stays private to your Stripe account until you separately submit it
# for review and build a Marketplace listing, so upload freely.
STRIPE_APP_SIGNING_SECRET=absec_...

# --- Bearer token auth -------------------------------------------------------
# Comma-separated list of accepted keys for `Authorization: Bearer <key>`.
# Generate with `openssl rand -hex 32`.
BEARER_TOKEN_KEYS=key-one,key-two

# Vercel sets CRON_SECRET automatically for cron invocations; it is
# accepted anywhere a bearer key is. https://vercel.com/docs/cron-jobs
CRON_SECRET=your-cron-secret

# --- Local dev API key -------------------------------------------------------
# Accepted as a bearer token ONLY when NODE_ENV=development (i.e. `next dev`).
# Lets you curl authenticated routes locally without a session or real key.
DEV_API_KEY=local-dev-only-key

# --- JWT-in-URL tokens -------------------------------------------------------
# Signs the short-lived tokens minted by /api/stripe-app/token and verified
# at the route level by /api/public/* routes (src/lib/url-token.ts).
# Generate with `openssl rand -hex 32`.
URL_TOKEN_SECRET=your-url-token-secret-min-32-chars

# --- User API keys (future work) --------------------------------------------
# Per-user keys will be stored (hashed) in the database and checked in
# verifyApiKey() in src/lib/proxy-auth.ts. No env var needed yet.

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
# change to production when deploying to Vercel or other hosting
NODE_ENV=development
